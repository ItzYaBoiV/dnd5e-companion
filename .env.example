# Copy to .env and fill in your values — never commit .env

# ── PostgreSQL ─────────────────────────────────────────
POSTGRES_USER=dnd5e_user
POSTGRES_PASSWORD=change_this_strong_password
POSTGRES_DB=dnd5e_db

# ── App ────────────────────────────────────────────────
NODE_ENV=production

# ── AI Workers ─────────────────────────────────────────
# LiteLLM load balancer runs on this server (192.168.5.7)
# Backend calls it on localhost since they share the same machine
AI_BASE_URL=http://localhost:4000
AI_MODEL=llama3.1:8b

# ── Seeding ────────────────────────────────────────────
# Set true on first run to seed SRD data, then back to false
SEED_ON_START=false
