# Copy to backend/.env when running Prisma from the HOST (not inside Docker).
# Repo-root .env is NOT auto-loaded here — Prisma only loads backend/.env
#
# 1. Copy your POSTGRES_USER, POSTGRES_PASSWORD, POSTGRES_DB from ../.env
# 2. URL-encode special characters in the password (@ : # / etc.)
# 3. Port 55432 = postgres published in docker-compose.yml (127.0.0.1:55432 -> 5432)

DATABASE_URL="postgresql://dnd5e_user:change_this_strong_password@127.0.0.1:55432/dnd5e_db"
